{
  "name": "deps-conflict-resolver",
  "version": "1.0.0",
  "description": "A webpack/vite plugin that automatically resolves peer dependency conflicts by creating aliases for conflicting versions",
  "author": {
    "name": "ben-lau",
    "email": "408736066@qq.com",
    "url": "https://github.com/ben-lau"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack.d.ts",
        "default": "./dist/webpack.js"
      },
      "require": {
        "types": "./dist/webpack.d.cts",
        "default": "./dist/webpack.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "webpack": [
        "./dist/webpack.d.ts"
      ],
      "vite": [
        "./dist/vite.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "webpack",
    "vite",
    "plugin",
    "peer-dependencies",
    "dependency-resolver",
    "vue2",
    "vue3",
    "alias"
  ],
  "license": "MIT",
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/node": "^20.10.0",
    "@types/semver": "^7.5.6",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^4.0.16",
    "esbuild": "^0.27.4",
    "eslint": "^8.55.0",
    "release-it": "^19.2.4",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vite": "^7.2.7",
    "vitest": "^4.0.16",
    "webpack": "^5.103.0"
  },
  "dependencies": {
    "semver": "^7.5.4",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "vite": ">=4.0.0",
    "webpack": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
